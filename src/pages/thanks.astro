---
import Layout from '../layouts/Layout.astro';
---

<Layout title="送信完了" description="お問い合わせありがとうございました。">
  <section class="max-w-6xl mx-auto px-6 py-20 md:py-32 text-center">
    <span class="font-heading-en text-sm tracking-widest text-muted">THANK YOU</span>
    <h1 class="font-heading-ja text-xl md:text-3xl leading-tight tracking-tight mt-4 mb-8">
      送信が完了しました。
    </h1>
    <p class="text-muted leading-relaxed max-w-2xl mx-auto mb-12">
      お問い合わせいただきありがとうございます。<br />
      内容を確認のうえ、折り返しご連絡いたします。
    </p>
    <a href="/" class="inline-flex items-center gap-2 font-heading-en tracking-wide border border-line px-8 py-3 hover:bg-surface transition-colors">
      TOP へ戻る &rarr;
    </a>
  </section>
</Layout>
