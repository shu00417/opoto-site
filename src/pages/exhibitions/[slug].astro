---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('exhibitions', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const images = data.images && data.images.length > 0
  ? data.images
  : data.image
    ? [data.image]
    : [];

const paragraphs = data.description
  ? data.description.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean)
  : [];

const noteUrl = data.note || 'https://note.com/opoto_tottori';

const statusLabel: Record<string, string> = {
  current: '開催中',
  next: 'NEXT',
  upcoming: 'UPCOMING',
  past: 'PAST',
};
---

<Layout title={data.title} description={paragraphs[0] ?? `OPOTOで開催した展示「${data.title}」の記録です。`}>
  <section class="max-w-4xl mx-auto px-6 pt-12 md:pt-16">
    <a href="/exhibitions" class="inline-flex items-center gap-2 text-sm font-heading-en text-muted hover:text-ink transition-colors">
      &larr; EXHIBITIONS
    </a>
  </section>

  <!-- 画像 -->
  {images.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
        {images.map((img) => (
          <div class="bg-surface border border-line overflow-hidden">
            <img src={img} alt={data.title} class="w-full h-auto" loading="lazy" />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 本文 -->
  <section class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <span class="font-heading-en text-sm tracking-widest text-muted">
      {statusLabel[data.status]}{data.exhibitionType ? ` / ${data.exhibitionType}` : ''}
    </span>
    <h1 class="font-heading-ja text-2xl md:text-3xl leading-tight tracking-tight mt-4 mb-4">
      {data.title}
    </h1>
    {data.artist && (
      <p class="text-muted mb-2">{data.artist}</p>
    )}
    {data.period && (
      <p class="text-sm text-ink mb-10">{data.period}</p>
    )}

    {paragraphs.length > 0 && (
      <div class="space-y-5 max-w-2xl mb-10">
        {paragraphs.map((p) => (
          <p class="text-muted leading-relaxed text-sm whitespace-pre-line">{p}</p>
        ))}
      </div>
    )}

    <a
      href={noteUrl}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 text-sm font-heading-en border border-line px-6 py-3 hover:bg-surface transition-colors"
    >
      note でアーカイブを見る &rarr;
    </a>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 border-t-[0.5px] border-line text-center">
    <p class="text-muted mb-6">
      展示のご相談や、貸しギャラリーのご利用については、お気軽にお問い合わせください。
    </p>
    <a
      href="/contact"
      class="inline-flex items-center gap-2 font-heading-en tracking-wide border border-line px-8 py-3 hover:bg-surface transition-colors"
    >
      CONTACT &rarr;
    </a>
  </section>
</Layout>
