---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="WORKS" description="OPOTOがこれまで関わってきた撮影や展示の記録です。">
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 py-20 md:py-32">
    <span class="font-heading-en text-sm tracking-widest text-muted">WORKS</span>
    <h1 class="font-heading-ja text-3xl md:text-5xl leading-tight tracking-tight mt-4 mb-8">
      これまでの、記録。
    </h1>
    <p class="text-muted leading-relaxed max-w-2xl">
      OPOTOがこれまで関わってきた撮影や展示の記録です。今後も随時更新していきます。
    </p>
  </section>

  <!-- GRID -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    {works.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {works.map((item) => (
          <div class="group">
            <div class="aspect-[4/5] bg-surface border border-line overflow-hidden">
              <img
                src={item.data.image}
                alt={item.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <p class="mt-2 text-sm">{item.data.title}</p>
            {item.data.description && (
              <p class="text-xs text-muted leading-relaxed">{item.data.description}</p>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {Array.from({ length: 8 }).map(() => (
          <div class="aspect-[4/5] bg-surface border border-line flex items-center justify-center text-muted text-xs">
            Photo
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
