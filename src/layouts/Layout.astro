---
import '../styles/global.css';
import { Image } from 'astro:assets';
import opotoLogo from '../assets/opoto-logo-horizontal.png';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '鳥取市川端にあるフォトスタジオ＆ギャラリー。成人式の前撮りから家族写真まで対応するスタジオと、写真展・プリントサービスを行うギャラリーを運営しています。' } = Astro.props;

const pageTitle = title.includes('OPOTO') ? title : `${title} | OPOTO`;
const canonicalURL = new URL(Astro.url.pathname, 'https://opoto.jp');
const ogImage = 'https://opoto.jp/og-image.jpg';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Photo and Culture OPOTO",
  "url": "https://opoto.jp",
  "image": ogImage,
  "description": "鳥取市川端にあるフォトスタジオ＆ギャラリー。",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "川端1丁目119 裏側入口2階",
    "addressLocality": "鳥取市",
    "addressRegion": "鳥取県",
    "postalCode": "680-0036",
    "addressCountry": "JP"
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Thursday","Friday","Saturday","Sunday"], "opens": "11:00", "closes": "19:00" }
  ],
  "sameAs": [
    "https://www.instagram.com/opoto_photostudio/",
    "https://www.instagram.com/opoto_gallery/"
  ]
};

const navItems = [
  { href: '/studio', label: 'STUDIO' },
  { href: '/gallery', label: 'GALLERY' },
  { href: '/exhibitions', label: 'EXHIBITIONS' },
  { href: '/contents', label: 'CONTENTS' },
  { href: '/about', label: 'ABOUT' },
  { href: '/access', label: 'ACCESS' },
  { href: '/contact', label: 'CONTACT' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Photo and Culture OPOTO" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SJW36W1JVH"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SJW36W1JVH');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Zen+Old+Mincho:wght@400;500;700&family=Jost:wght@400;500;600&family=Noto+Sans+JP:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-base text-ink font-body antialiased">
    <div
      id="mobile-menu-backdrop"
      class="fixed inset-0 z-40 hidden bg-ink/30 md:hidden"
      aria-hidden="true"
    ></div>

    <header class="sticky top-0 z-50 relative border-b border-line bg-base/90 backdrop-blur-sm">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-5">
        <a href="/" class="relative z-50 flex items-center">
          <Image src={opotoLogo} alt="Photo and Culture OPOTO" class="h-7 md:h-8 w-auto" />
        </a>
        <nav class="hidden md:flex gap-8 text-sm font-heading-en tracking-wide">
          {navItems.map((item) => (
            <a href={item.href} class="hover:text-muted transition-colors">{item.label}</a>
          ))}
        </nav>
        <button
          type="button"
          id="mobile-menu-toggle"
          class="relative z-50 md:hidden flex h-10 w-10 items-center justify-center -mr-2 rounded-full hover:bg-surface transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="メニューを開く"
        >
          <svg id="mobile-menu-icon-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg id="mobile-menu-icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden h-6 w-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div
        id="mobile-menu"
        class="absolute inset-x-0 top-full hidden md:hidden border-t border-line bg-base shadow-[0_8px_24px_rgba(0,0,0,0.08)]"
        aria-hidden="true"
      >
        <nav class="max-w-6xl mx-auto px-6 py-3">
          {navItems.map((item, i) => (
            <a
              href={item.href}
              class:list={[
                'block py-4 text-lg font-heading-en tracking-wide transition-colors active:bg-surface',
                i < navItems.length - 1 && 'border-b border-line',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const backdrop = document.getElementById('mobile-menu-backdrop');
      const iconOpen = document.getElementById('mobile-menu-icon-open');
      const iconClose = document.getElementById('mobile-menu-icon-close');
      let isOpen = false;

      const setOpen = (open: boolean) => {
        if (!toggle || !menu) return;
        isOpen = open;
        menu.classList.toggle('hidden', !open);
        menu.classList.toggle('block', open);
        backdrop?.classList.toggle('hidden', !open);
        menu.setAttribute('aria-hidden', open ? 'false' : 'true');
        backdrop?.setAttribute('aria-hidden', open ? 'false' : 'true');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
        iconOpen?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
        document.body.classList.toggle('overflow-hidden', open);
      };

      toggle?.addEventListener('click', () => setOpen(!isOpen));
      backdrop?.addEventListener('click', () => setOpen(false));
      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setOpen(false));
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) setOpen(false);
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="border-t border-line mt-24">
      <div class="max-w-6xl mx-auto px-6 py-12 grid gap-10 md:grid-cols-2 text-sm">
        <div>
          <p class="font-logo text-lg mb-2">Photo and Culture OPOTO</p>
          <p class="text-muted mt-2">〒680-0036</p>
          <p class="text-muted">鳥取県鳥取市川端1丁目119　裏側入口2階</p>
          <p class="text-muted mt-4">営業時間　11:00〜19:00</p>
          <p class="text-muted">定休日　月・火・水(展示会期間中は月のみ休廊)</p>
        </div>
        <div>
          <p class="font-heading-en mb-2 tracking-wide">LINKS</p>
          <ul class="grid grid-cols-2 gap-x-6 gap-y-2">
            <li>
              <a href="https://www.instagram.com/opoto_photostudio/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-muted transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4 flex-shrink-0">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="0.6" fill="currentColor" stroke="none" />
                </svg>
                Instagram (Studio)
              </a>
            </li>
            <li>
              <a href="https://www.instagram.com/opoto_gallery/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-muted transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4 flex-shrink-0">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="0.6" fill="currentColor" stroke="none" />
                </svg>
                Instagram (Gallery)
              </a>
            </li>
            <li>
              <a href="https://opotogallery.base.shop/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-muted transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4 flex-shrink-0">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.5 8h11l1 12h-13l1-12z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 8a3 3 0 016 0" />
                </svg>
                Online Shop (BASE)
              </a>
            </li>
            <li>
              <a href="https://note.com/opoto_tottori" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-muted transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4 flex-shrink-0">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 4.5A1.5 1.5 0 016.5 3H14l5 5v11.5a1.5 1.5 0 01-1.5 1.5h-11A1.5 1.5 0 015 19.5v-15z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 3v5h5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5h7M8.5 16h7" />
                </svg>
                note
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="text-center text-xs text-muted pb-6">&copy; Photo and Culture OPOTO</div>
    </footer>

    <Lightbox />
  </body>
</html>
